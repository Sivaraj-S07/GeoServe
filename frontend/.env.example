# ── API Configuration ──────────────────────────────────────────────────────────
# Leave blank for local dev (Vite proxies /api → localhost:5000 automatically)
# Set in production: VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=

# ── Admin Panel URL (for admin login redirect) ─────────────────────────────────
# Leave blank for local dev (defaults to http://localhost:5174)
# Set in production: VITE_ADMIN_URL=https://your-admin-panel.onrender.com
VITE_ADMIN_URL=
