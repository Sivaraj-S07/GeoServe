# ════════════════════════════════════════════════════════════════════════════
#  GeoServe Shared Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#
#  REQUIRES: Node.js >= 18.0.0 (uses native fetch for pincode API lookup)
# ════════════════════════════════════════════════════════════════════════════

PORT=5000

# ── CORS: Allowed frontend origins (comma-separated, NO trailing slashes) ────
# Local development:
#   CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Production (replace with your actual Vercel/Netlify/Render URLs):
#   CORS_ORIGIN=https://your-app.vercel.app,https://your-admin.vercel.app
#
# ⚠️  IMPORTANT FOR DEPLOYMENT:
#   Set this env var in your hosting dashboard (Render/Railway/etc.) to your
#   deployed frontend URLs. Do NOT leave it blank in production or auth
#   requests will be blocked by CORS.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── JWT Secret ───────────────────────────────────────────────────────────────
# Use a long random string in production (min 32 chars recommended).
# In Render, use "Generate Value" to auto-create a secure secret.
JWT_SECRET=change_me_in_production_use_a_long_random_string

# ── Razorpay (optional) ──────────────────────────────────────────────────────
# Leave blank to run in simulation/demo mode (no real payments).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
