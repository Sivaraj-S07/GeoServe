# ── PostgreSQL (Neon or any Postgres provider) ────────────────────────────────
# SECURITY: Never commit your real DATABASE_URL. Use environment variables in production.
DATABASE_URL=postgresql://neondb_owner:npg_PVHmZ1vTn6Di@ep-morning-tree-aoherjr5-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will refuse to start without this.
JWT_SECRET=c7f3a9b2e1d4f8a5c2e9b7d3f6a1c8e5b2d9f4a7c1e3b6d8f2a5c9e7b4d1f3a6

# ── Cookie ────────────────────────────────────────────────────────────────────
# Optional separate secret for signed cookies (defaults to JWT_SECRET if unset)
COOKIE_SECRET=REPLACE_WITH_ANOTHER_RANDOM_SECRET

# ── Razorpay Payouts (leave blank for simulation mode) ───────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
