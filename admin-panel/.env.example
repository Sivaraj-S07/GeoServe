# Admin Panel environment variables
# Copy this file to .env and fill in your values

# Backend API URL
#
# LOCAL DEV: Leave blank — Vite automatically proxies /api → http://localhost:5000
#   VITE_API_URL=
#
# PRODUCTION (Vercel): Set to your Render backend URL WITH /api suffix:
#   VITE_API_URL=https://your-geoserve-backend.onrender.com/api
#
# ⚠️  Do NOT set this to http://localhost:5000/api for production.
#     The browser cannot reach localhost on Vercel — it WILL cause "Failed to fetch" errors.
VITE_API_URL=
